# Supabase cloud sync (OPTIONAL).
# Leave BOTH unset to run in local-only mode (data stays in the browser).
# Set both to enable cloud sync; the app will then ask for a household code.
#
# The Vercel Supabase integration's NEXT_PUBLIC_SUPABASE_URL /
# NEXT_PUBLIC_SUPABASE_ANON_KEY (or NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY)
# are also picked up automatically — no need to duplicate them as VITE_*.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
